---
// Internal imports
import { db } from '@db';
import { spotlightEvents, submissions, reviews, filmmakers } from '@db/schema';
import { formatDuration, formatRuntime, calculateTotalRuntime } from '@lib/film-utils';
import { formatDate } from '@lib/datetime';
import BaseLayout from '@layouts/BaseLayout.astro';
import SubmissionForm from '@components/SubmissionForm.astro';

// External packages
import { eq, desc, asc } from 'drizzle-orm';

const selectedStatus = Astro.url.searchParams.get('status') || 'all';

// Events first, so we can default to the most recent event when none is
// specified — showing every event's films mixed together is confusing
const allEvents = await db
  .select({
    id: spotlightEvents.id,
    title: spotlightEvents.title,
    eventDate: spotlightEvents.eventDate,
  })
  .from(spotlightEvents)
  .orderBy(desc(spotlightEvents.eventDate));

const requestedEventId = Astro.url.searchParams.get('event');
if (!requestedEventId && allEvents.length > 0) {
  const params = new URLSearchParams(Astro.url.searchParams);
  params.set('event', String(allEvents[0].id));
  return Astro.redirect(`/admin/events/submissions?${params.toString()}`);
}
const selectedEventId = requestedEventId;

// Build submission query (filtered to the selected event)
let submissionsQuery = db
  .select()
  .from(submissions)
  .orderBy(asc(submissions.sortOrder), desc(submissions.createdAt))
  .$dynamic();

if (selectedEventId) {
  submissionsQuery = submissionsQuery.where(eq(submissions.eventId, Number(selectedEventId)));
}

// Run remaining queries in parallel
const [allSubmissions, allReviews] = await Promise.all([
  submissionsQuery,

  db.select({
    submissionId: reviews.submissionId,
    adminName: filmmakers.name,
    vote: reviews.vote,
    createdAt: reviews.createdAt,
  })
  .from(reviews)
  .innerJoin(filmmakers, eq(reviews.adminId, filmmakers.id)),
]);

// Fetch the full selected event (needed to render the manual-entry form)
let selectedEvent = null;
if (selectedEventId) {
  [selectedEvent] = await db
    .select()
    .from(spotlightEvents)
    .where(eq(spotlightEvents.id, Number(selectedEventId)));
}

// Filter by status client-side if needed (simpler for small datasets)
const filteredSubmissions = selectedStatus === 'all'
  ? allSubmissions
  : allSubmissions.filter(s => s.status === selectedStatus);

// Calculate stats (films only — breaks aren't submissions)
const films = allSubmissions.filter(s => s.itemType !== 'break');
const stats = {
  total: films.length,
  pending: films.filter(s => s.status === 'pending').length,
  approved: films.filter(s => s.status === 'approved').length,
  rejected: films.filter(s => s.status === 'rejected').length,
  future: films.filter(s => s.status === 'future').length,
};

// Non-zero status counts for the segmented distribution bar
const statusCounts = [
  { key: 'pending', label: 'Pending', count: stats.pending },
  { key: 'approved', label: 'Approved', count: stats.approved },
  { key: 'rejected', label: 'Not Selected', count: stats.rejected },
  { key: 'future', label: 'Future', count: stats.future },
].filter(s => s.count > 0);

// Runtime includes breaks so it reflects the actual run-of-show length
const approvedSubs = allSubmissions.filter(s => s.status === 'approved');
const totalRuntime = calculateTotalRuntime(approvedSubs);

// Build review map with voter details for tooltips
const reviewMap = new Map<number, { upVotes: number; downVotes: number; tooltip: string }>();
for (const r of allReviews) {
  if (!reviewMap.has(r.submissionId)) {
    reviewMap.set(r.submissionId, { upVotes: 0, downVotes: 0, tooltip: '' });
  }
  const entry = reviewMap.get(r.submissionId)!;
  if (r.vote === 'up') entry.upVotes++;
  if (r.vote === 'down') entry.downVotes++;
  const emoji = r.vote === 'up' ? '👍' : r.vote === 'down' ? '👎' : '💬';
  const date = formatDate(r.createdAt, { month: 'short', day: 'numeric' });
  entry.tooltip += `${entry.tooltip ? '\n' : ''}${r.adminName} ${emoji} — ${date}`;
}

// Hide Notes / Votes columns if nothing in the current view has any.
// Notes are per-submission; votes are tracked via the review map.
const filmRows = filteredSubmissions.filter(s => s.itemType !== 'break');
const showNotesCol = filmRows.some(s => !!s.adminNotes);
const showVotesCol = filmRows.some(s => reviewMap.has(s.id));

// Trailing colspan for break rows: covers Status + (Notes?) + (Votes?)
const breakTrailingColspan = 1 + (showNotesCol ? 1 : 0) + (showVotesCol ? 1 : 0);

// Admin-entered manual submissions default to this email when no real one was
// supplied — suppress the mailto icon so it doesn't look like a real contact.
const ADMIN_DEFAULT_SUBMITTER_EMAIL = 'avlfilmgroup@gmail.com';
---

<BaseLayout title="Admin - Submissions">
  <div class="admin-header">
    <h1>Submissions</h1>
  </div>

  <div class="admin-section">
    <div class="header-stats-container">
      <div class="header-left">
        <div class="filters">
          <div class="filter-group">
            <label for="event-filter">Event:</label>
            <select id="event-filter">
              {allEvents.map((ev) => (
                <option value={ev.id} selected={selectedEventId === String(ev.id)}>{ev.title} — {formatDate(ev.eventDate, { month: 'short', day: 'numeric', year: 'numeric' })}</option>
              ))}
            </select>
          </div>
          <div class="filter-group">
            <label for="status-filter">Status:</label>
            <select id="status-filter">
              {[
                { value: 'all', label: 'All' },
                { value: 'pending', label: 'Pending' },
                { value: 'approved', label: 'Approved' },
                { value: 'rejected', label: 'Not Selected' },
                { value: 'future', label: 'Future' },
              ].map((s) => (
                <option value={s.value} selected={selectedStatus === s.value}>{s.label}</option>
              ))}
            </select>
          </div>
        </div>
        {selectedEvent && (
          <div class="table-actions">
            <button class="btn-secondary" id="add-submission-btn" type="button">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 2V8M8 8V14M8 8H14M8 8H2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              Add Submission
            </button>
            <button class="btn-secondary" id="add-break-btn" type="button">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="3" width="2.5" height="10" rx="1.25" fill="currentColor"/>
                <rect x="9.5" y="3" width="2.5" height="10" rx="1.25" fill="currentColor"/>
              </svg>
              Add Break
            </button>
            <button class="btn-secondary" id="request-files-btn" type="button">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="1.5" y="3" width="13" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M1.5 5L8 9.5L14.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Request Files
            </button>
          </div>
        )}
      </div>

      {selectedEventId && (
        <div class="stats-section">
          {statusCounts.length > 0 && (
            <div class="seg-stats">
              <div class="seg-bar">
                {statusCounts.map((s) => (
                  <span class={`seg ${s.key}`} style={`flex: ${s.count}`}></span>
                ))}
              </div>
              <div class="seg-legend">
                {statusCounts.map((s) => (
                  <span><i class={`dot ${s.key}`}></i>{s.label} {s.count}</span>
                ))}
              </div>
            </div>
          )}
          <table class="stats-table runtime-table">
            <thead>
              <tr>
                <th>Runtime</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="runtime-display">{formatRuntime(totalRuntime)}</td>
              </tr>
            </tbody>
          </table>
        </div>
      )}
    </div>

    <!-- Submissions Table -->
    {filteredSubmissions.length === 0 ? (
      <div class="empty-state">No submissions found.</div>
    ) : (
      <table class="submissions-table">
        <thead>
          <tr>
            <th class="drag-col"></th>
            <th>Film Title</th>
            <th>Filmmaker</th>
            <th>Genre</th>
            <th>Length</th>
            <th>Status</th>
            {showNotesCol && <th>Notes</th>}
            {showVotesCol && <th>Votes</th>}
          </tr>
        </thead>
        <tbody>
          {filteredSubmissions.map((sub) => {
            if (sub.itemType === 'break') {
              return (
                <tr class="break-row" data-id={sub.id} draggable="true">
                  <td class="drag-handle" title="Drag to reorder">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="6" cy="4" r="1.25" fill="currentColor"/>
                      <circle cx="10" cy="4" r="1.25" fill="currentColor"/>
                      <circle cx="6" cy="8" r="1.25" fill="currentColor"/>
                      <circle cx="10" cy="8" r="1.25" fill="currentColor"/>
                      <circle cx="6" cy="12" r="1.25" fill="currentColor"/>
                      <circle cx="10" cy="12" r="1.25" fill="currentColor"/>
                    </svg>
                  </td>
                  <td colspan="3">
                    <input
                      type="text"
                      class="break-label-input"
                      data-break-id={sub.id}
                      data-current={sub.filmTitle}
                      value={sub.filmTitle}
                      aria-label="Break label"
                    />
                  </td>
                  <td class="break-duration">
                    <input
                      type="number"
                      class="break-duration-input"
                      data-break-id={sub.id}
                      data-current={Math.round(sub.filmLength / 60)}
                      value={Math.round(sub.filmLength / 60)}
                      min="1"
                      step="1"
                      aria-label="Break duration in minutes"
                    />
                    <span class="break-duration-unit">min</span>
                  </td>
                  <td colspan={breakTrailingColspan} class="break-actions">
                    <button class="break-delete" type="button" data-break-id={sub.id} title="Remove break">&times;</button>
                  </td>
                </tr>
              );
            }
            const rv = reviewMap.get(sub.id);
            return (
              <tr data-id={sub.id} draggable="true">
                <td class="drag-handle" title="Drag to reorder">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="6" cy="4" r="1.25" fill="currentColor"/>
                    <circle cx="10" cy="4" r="1.25" fill="currentColor"/>
                    <circle cx="6" cy="8" r="1.25" fill="currentColor"/>
                    <circle cx="10" cy="8" r="1.25" fill="currentColor"/>
                    <circle cx="6" cy="12" r="1.25" fill="currentColor"/>
                    <circle cx="10" cy="12" r="1.25" fill="currentColor"/>
                  </svg>
                </td>
                <td class="title-cell"><a href={`/admin/events/reviews?id=${sub.id}`}>{sub.filmTitle}</a></td>
                <td>
                  {sub.submitterName}
                  {sub.submitterEmail !== ADMIN_DEFAULT_SUBMITTER_EMAIL && (
                    <a href={`mailto:${sub.submitterEmail}`} class="email-icon" title={sub.submitterEmail}>
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="1.5" y="3" width="13" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M1.5 5L8 9.5L14.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  )}
                </td>
                <td>{sub.filmGenre === 'Other' ? sub.filmGenreOther : sub.filmGenre}</td>
                <td>{formatDuration(sub.filmLength)}</td>
                <td class="status-cell">
                  <select class={`status-select ${sub.status}`} data-id={sub.id} data-current={sub.status} aria-label="Status">
                    <option value="pending" selected={sub.status === 'pending'}>Pending</option>
                    <option value="approved" selected={sub.status === 'approved'}>Approved</option>
                    <option value="rejected" selected={sub.status === 'rejected'}>Not Selected</option>
                    <option value="future" selected={sub.status === 'future'}>Future</option>
                  </select>
                  {sub.status === 'approved' && sub.fullResVideoUrl && (
                    <span class="link-indicator" title="Full-res video link on file">&#128279;</span>
                  )}
                </td>
                {showNotesCol && (
                  <td class="notes-cell">
                    {sub.adminNotes ? (
                      <span class="has-tooltip">&#128221;<span class="tooltip">{sub.adminNotes}</span></span>
                    ) : '—'}
                  </td>
                )}
                {showVotesCol && (
                  <td class="votes-cell">
                    {rv ? (
                      <span class="has-tooltip votes-display">
                        {rv.upVotes > 0 && <span>&#128077;</span>}
                        {rv.downVotes > 0 && <span>&#128078;</span>}
                        {rv.upVotes === 0 && rv.downVotes === 0 && <span>&#128172;</span>}
                        <span class="tooltip">{rv.tooltip}</span>
                      </span>
                    ) : (
                      <span class="no-votes">—</span>
                    )}
                  </td>
                )}
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </div>

  <!-- Confirmation Modal -->
  <div id="request-files-modal" class="modal">
    <div class="modal-overlay"></div>
    <div class="modal-content modal-small">
      <button class="modal-close">&times;</button>
      <div class="modal-body">
        <h2>Request Files</h2>
        <p id="modal-message"></p>
        <div class="table-wrapper">
          <table id="modal-email-table" class="modal-table">
            <thead>
              <tr>
                <th>Film Title</th>
                <th>Email</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="modal-email-list"></tbody>
          </table>
        </div>
        <div class="modal-actions">
          <button class="btn-secondary" id="modal-cancel-btn">Cancel</button>
          <button class="btn-primary" id="modal-confirm-btn">Send Emails</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Add Submission Modal -->
  {selectedEvent && (
    <div id="add-submission-modal" class="modal">
      <div class="modal-overlay"></div>
      <div class="modal-content modal-small">
        <button class="modal-close">&times;</button>
        <div class="modal-body">
          <h2>Add Submission &mdash; {selectedEvent.title}</h2>
          <SubmissionForm
            event={selectedEvent}
            action="/admin/api/submissions/create"
            adminMode={true}
            submitLabel="Add Submission"
          />
        </div>
      </div>
    </div>
  )}

  <!-- Add Break Modal -->
  {selectedEvent && (
    <div id="add-break-modal" class="modal">
      <div class="modal-overlay"></div>
      <div class="modal-content modal-small">
        <button class="modal-close">&times;</button>
        <div class="modal-body">
          <h2>Add Break</h2>
          <form id="break-form" class="break-form" data-event-id={selectedEvent.id}>
            <div class="form-group">
              <label for="break-label">Label</label>
              <input type="text" id="break-label" name="label" required placeholder="Intermission, Q&amp;A, Setup..." />
            </div>
            <div class="form-group">
              <label for="break-duration">Duration (minutes)</label>
              <input type="number" id="break-duration" name="durationMinutes" required min="1" step="1" placeholder="15" />
            </div>
            <div id="break-message" class="form-message" style="display: none;"></div>
            <div class="modal-actions">
              <button type="button" class="btn-secondary" id="break-cancel-btn">Cancel</button>
              <button type="submit" class="btn-primary" id="break-submit-btn">Add Break</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  )}

</BaseLayout>

<script is:inline id="submissions-data" type="application/json" set:html={JSON.stringify({
  approvedWithoutFiles: allSubmissions
    .filter(s => s.status === 'approved' && s.itemType !== 'break' && !s.fullResVideoUrl && selectedEventId && s.eventId === Number(selectedEventId))
    .map(s => ({ id: s.id, email: s.submitterEmail, filmTitle: s.filmTitle, status: s.status }))
})}></script>

<script>
  import { setupModal } from '@lib/modal';
  import { showFormMessage } from '@lib/form-utils';

  // Setup modals
  const requestFilesModal = setupModal('request-files-modal');
  const addSubmissionModal = setupModal('add-submission-modal');
  const addBreakModal = setupModal('add-break-modal');

  // Open the Add Submission modal
  document.getElementById('add-submission-btn')?.addEventListener('click', () => {
    addSubmissionModal?.open();
  });

  // Add Break modal
  document.getElementById('add-break-btn')?.addEventListener('click', () => {
    addBreakModal?.open();
  });
  document.getElementById('break-cancel-btn')?.addEventListener('click', () => {
    addBreakModal?.close();
  });

  const breakForm = document.getElementById('break-form') as HTMLFormElement | null;
  if (breakForm) {
    const breakMessage = document.getElementById('break-message') as HTMLDivElement;
    const breakSubmitBtn = document.getElementById('break-submit-btn') as HTMLButtonElement;

    breakForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      breakSubmitBtn.disabled = true;
      breakSubmitBtn.textContent = 'Adding...';
      breakMessage.style.display = 'none';

      const formData = new FormData(breakForm);
      try {
        const res = await fetch('/admin/api/submissions/break', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            eventId: Number(breakForm.dataset.eventId),
            label: formData.get('label'),
            durationMinutes: Number(formData.get('durationMinutes')),
          }),
        });
        const result = await res.json();
        if (!res.ok) throw new Error(result.error || 'Failed to add break');
        window.location.reload();
      } catch (err) {
        showFormMessage(breakMessage, err instanceof Error ? err.message : 'Something went wrong', 'error');
        breakSubmitBtn.disabled = false;
        breakSubmitBtn.textContent = 'Add Break';
      }
    });
  }

  // Inline-edit a break field (label or duration). Commits on blur/Enter; Esc reverts.
  function bindBreakInput(input: HTMLInputElement, buildPayload: (value: string) => Record<string, unknown> | null) {
    const commit = async () => {
      const previous = input.dataset.current!;
      const value = input.value.trim();
      if (value === previous) return;

      const payload = buildPayload(value);
      if (!payload) {
        input.value = previous;
        return;
      }

      input.disabled = true;
      try {
        const res = await fetch('/admin/api/submissions/break', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: Number(input.dataset.breakId), ...payload }),
        });
        const result = await res.json();
        if (!res.ok) throw new Error(result.error || 'Failed to update break');
        // Reload so runtime + display stay in sync
        window.location.reload();
      } catch (err) {
        console.error('Failed to update break', err);
        alert(err instanceof Error ? err.message : 'Failed to update break');
        input.value = previous;
        input.disabled = false;
      }
    };

    input.addEventListener('blur', commit);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        input.blur();
      } else if (e.key === 'Escape') {
        input.value = input.dataset.current!;
        input.blur();
      }
    });
    // Prevent drag from initiating when interacting with the input
    input.addEventListener('mousedown', (e) => e.stopPropagation());
  }

  document.querySelectorAll('.break-duration-input').forEach((el) => {
    bindBreakInput(el as HTMLInputElement, (value) => {
      const minutes = Number(value);
      if (!Number.isFinite(minutes) || minutes <= 0) return null;
      return { durationMinutes: minutes };
    });
  });

  document.querySelectorAll('.break-label-input').forEach((el) => {
    bindBreakInput(el as HTMLInputElement, (value) => {
      if (!value) return null;
      return { label: value };
    });
  });

  // Delete a break
  document.querySelectorAll('.break-delete').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const id = Number((btn as HTMLElement).dataset.breakId);
      if (!confirm('Remove this break from the schedule?')) return;
      try {
        const res = await fetch('/admin/api/submissions/break', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (!res.ok) throw new Error('Failed to delete break');
        window.location.reload();
      } catch (err) {
        console.error('Failed to delete break', err);
        alert('Failed to delete break');
      }
    });
  });

  // Inline status updates
  document.querySelectorAll('.status-select').forEach((el) => {
    const select = el as HTMLSelectElement;
    select.addEventListener('change', async () => {
      const id = Number(select.dataset.id);
      const previous = select.dataset.current!;
      const status = select.value;

      // The endpoint requires a reason when rejecting
      let rejectionReason: string | null = null;
      if (status === 'rejected') {
        rejectionReason = prompt('Rejection reason (required):');
        if (!rejectionReason || !rejectionReason.trim()) {
          select.value = previous;
          return;
        }
      }

      select.disabled = true;
      try {
        const res = await fetch('/admin/api/submissions/update-status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, status, rejectionReason }),
        });
        const result = await res.json();
        if (!res.ok) throw new Error(result.error || 'Failed to update status');
        // Reload so runtime, stats, the status filter, and link indicator stay in sync
        window.location.reload();
      } catch (err) {
        console.error('Failed to update status', err);
        alert(err instanceof Error ? err.message : 'Failed to update status');
        select.value = previous;
        select.disabled = false;
      }
    });
  });

  // Filter navigation
  const eventFilter = document.getElementById('event-filter') as HTMLSelectElement;
  const statusFilter = document.getElementById('status-filter') as HTMLSelectElement;

  function applyFilters() {
    const params = new URLSearchParams();
    if (eventFilter.value) params.set('event', eventFilter.value);
    if (statusFilter.value && statusFilter.value !== 'all') params.set('status', statusFilter.value);
    window.location.search = params.toString();
  }

  eventFilter.addEventListener('change', applyFilters);
  statusFilter.addEventListener('change', applyFilters);

  // Request files for all approved submissions without full-res video
  const requestFilesBtn = document.getElementById('request-files-btn');
  if (requestFilesBtn && requestFilesModal) {
    requestFilesBtn.addEventListener('click', () => {
      const data = JSON.parse(document.getElementById('submissions-data')?.textContent || '{}');
      const submissions = data.approvedWithoutFiles || [];

      if (submissions.length === 0) {
        alert('No approved submissions need file requests.');
        return;
      }

      // Populate modal
      const modalMessage = document.getElementById('modal-message')!;
      const modalEmailList = document.getElementById('modal-email-list')!;

      modalMessage.textContent = `Send file request emails to ${submissions.length} filmmaker${submissions.length > 1 ? 's' : ''}?`;
      modalEmailList.innerHTML = submissions.map((s: any) =>
        `<tr>
          <td>${s.filmTitle}</td>
          <td>${s.email}</td>
          <td><span class="status-badge ${s.status}">${s.status}</span></td>
        </tr>`
      ).join('');

      requestFilesModal.open();
    });

    // Cancel button
    document.getElementById('modal-cancel-btn')?.addEventListener('click', () => {
      requestFilesModal?.close();
    });

    // Confirm button
    document.getElementById('modal-confirm-btn')?.addEventListener('click', async () => {
      const data = JSON.parse(document.getElementById('submissions-data')?.textContent || '{}');
      const submissions = data.approvedWithoutFiles || [];

      const btn = document.getElementById('modal-confirm-btn') as HTMLButtonElement;
      const originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Sending...';

      try {
        const results = await Promise.all(
          submissions.map((s: any) =>
            fetch('/admin/api/submissions/request-file', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ submissionId: s.id }),
            })
          )
        );

        const allSuccessful = results.every(r => r.ok);
        if (!allSuccessful) {
          throw new Error('Some emails failed to send');
        }

        // Update the Request Files button
        const requestBtn = document.getElementById('request-files-btn') as HTMLButtonElement;
        const reqOriginalText = requestBtn.textContent;
        requestBtn.textContent = `✓ ${submissions.length} Email${submissions.length > 1 ? 's' : ''} Sent`;
        requestBtn.style.background = '#10b981';

        requestFilesModal?.close();

        setTimeout(() => {
          requestBtn.textContent = reqOriginalText;
          requestBtn.style.background = '';
        }, 3000);
      } catch (err) {
        console.error('Failed to send file requests', err);
        alert('Failed to send some file request emails');
      } finally {
        btn.disabled = false;
        btn.textContent = originalText;
      }
    });
  }

  // Drag and drop reordering
  const tbody = document.querySelector('.submissions-table tbody') as HTMLTableSectionElement | null;
  if (tbody) {
    let dragRow: HTMLTableRowElement | null = null;

    tbody.addEventListener('dragstart', (e) => {
      const row = (e.target as HTMLElement).closest('tr') as HTMLTableRowElement;
      if (!row) return;
      dragRow = row;
      row.classList.add('dragging');
      e.dataTransfer!.effectAllowed = 'move';
    });

    const clearDropMarkers = () =>
      tbody.querySelectorAll('.drop-before, .drop-after').forEach((el) => el.classList.remove('drop-before', 'drop-after'));

    tbody.addEventListener('dragend', () => {
      if (dragRow) dragRow.classList.remove('dragging');
      dragRow = null;
      clearDropMarkers();
    });

    tbody.addEventListener('dragover', (e) => {
      e.preventDefault();
      e.dataTransfer!.dropEffect = 'move';
      const targetRow = (e.target as HTMLElement).closest('tr') as HTMLTableRowElement;
      // Ignore non-draggable rows (e.g. the Request Files action row has no data-id)
      if (!targetRow || targetRow === dragRow || !targetRow.dataset.id) return;

      // Line goes on the side of the row the cursor is closest to — that's the
      // insertion point. No live reflow, so the line never desyncs from the drop.
      const rect = targetRow.getBoundingClientRect();
      const after = e.clientY > rect.top + rect.height / 2;
      clearDropMarkers();
      targetRow.classList.add(after ? 'drop-after' : 'drop-before');
    });

    tbody.addEventListener('drop', async (e) => {
      e.preventDefault();

      // Commit the move at the marked insertion point
      const beforeEl = tbody.querySelector('tr.drop-before');
      const afterEl = tbody.querySelector('tr.drop-after');
      if (dragRow && beforeEl) beforeEl.before(dragRow);
      else if (dragRow && afterEl) afterEl.after(dragRow);
      clearDropMarkers();

      const rows = [...tbody.querySelectorAll('tr[data-id]')];
      const order = rows.map((row, i) => ({
        id: Number((row as HTMLElement).dataset.id),
        sortOrder: i,
      }));

      try {
        const res = await fetch('/admin/api/submissions/reorder', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ order }),
        });
        if (!res.ok) {
          console.error('Failed to save order');
        }
      } catch (err) {
        console.error('Failed to save order', err);
      }
    });
  }
</script>

