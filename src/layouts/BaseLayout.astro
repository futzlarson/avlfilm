---
// Side effect imports
import '@styles/global.css';

// Internal imports
import Banner from '@components/Banner.astro';
import RollbarClient from '@components/RollbarClient.astro';
import { getUpcomingSpotlightEvent } from '@lib/spotlight-cache';

// External packages
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  structuredData?: object;
}

const { title, description, keywords, ogImage: ogImageProp, structuredData } = Astro.props;
const ogImage = ogImageProp || 'https://avlfilm.com/community.jpg';
const defaultDescription = 'Connecting filmmakers and film enthusiasts across Western North Carolina with festivals, crew directories, events, and resources.';
const finalDescription = description || defaultDescription;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);

// Show the public Spotlight nav link only when there's an upcoming event.
const hasUpcomingSpotlight = (await getUpcomingSpotlightEvent()) !== null;

// Get user from middleware
let user = Astro.locals.user;

// Dev override for testing admin/non-admin UI
if (user && import.meta.env.DEV && import.meta.env.DEV_OVERRIDE_ADMIN) {
  user = { ...user, isAdmin: import.meta.env.DEV_OVERRIDE_ADMIN === 'true' };
}

// Admin dropdown menu (rendered under the 🦄). Icons are Feather-style SVGs.
const icon = (paths: string) =>
  `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${paths}</svg>`;

const adminMenu: { href: string; label: string; icon: string; divider?: boolean }[] = [
  { href: '/admin', label: 'Dashboard', icon: icon('<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>') },
  { href: '/admin/filmmakers', label: 'Filmmakers', icon: icon('<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>') },
  { href: '/admin/calendar', label: 'Calendar', icon: icon('<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>') },
  { href: '/admin/events', label: 'Spotlight', icon: icon('<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>') },
  { href: '/admin/events/submissions', label: 'Submissions', icon: icon('<rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/>') },
  { href: '/admin/style-guide', label: 'Style Guide', icon: icon('<path d="M12 2C6.5 2 2 6 2 11c0 3 2.2 4.5 4.5 4.5.9 0 1.5.7 1.5 1.5 0 2 1.6 3 3.5 3C18.5 21 22 16.7 22 11.3 22 6 17.5 2 12 2z"/><circle cx="6.5" cy="11.5" r="1.1" fill="currentColor"/><circle cx="9.5" cy="7.5" r="1.1" fill="currentColor"/><circle cx="14.5" cy="7.5" r="1.1" fill="currentColor"/><circle cx="17.5" cy="11" r="1.1" fill="currentColor"/>') },
  { href: '/account/profile', label: 'My Profile', icon: icon('<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>'), divider: true },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - AVL Film</title>
    <meta name="description" content={finalDescription} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:site_name" content="AVL Film" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="900">
    <meta property="og:image:type" content="image/jpeg">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎬</text></svg>" />

    <!-- JSON-LD Structured Data -->
    {structuredData && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(structuredData)}
      />
    )}

    <RollbarClient />
  </head>
  <body>
    <Banner />

    <header>
      <nav>
        <a href="/" class="logo"><img src="/logo/wordmark.svg" alt="AVL Film" /></a>
        <ul class="nav-links">
          <li class="home-link"><a href="/">Home</a></li>
          {hasUpcomingSpotlight && <li><a href="/spotlight" class="spotlight-link">Spotlight</a></li>}
          <li><a href="/calendar">Calendar</a></li>
          <li><a href="/directory">Directory</a></li>
          <li class:list={[{ 'mobile-hide-for-spotlight': hasUpcomingSpotlight }]}><a href="/resources">Resources</a></li>
          {
            user?.isAdmin ? (
              <li class="admin-menu">
                <button
                  type="button"
                  class="admin-menu-toggle"
                  id="admin-menu-toggle"
                  aria-haspopup="true"
                  aria-expanded="false"
                  aria-label="Admin menu"
                >🦄</button>
                <div class="admin-menu-dropdown" id="admin-menu-dropdown">
                  {adminMenu.map((item) => (
                    <Fragment>
                      {item.divider && <hr />}
                      <a href={item.href}>
                        <span class="mi-icon" set:html={item.icon}></span>
                        <span>{item.label}</span>
                      </a>
                    </Fragment>
                  ))}
                </div>
              </li>
            ) : user ? (
              <li class="account-link"><a href="/account/profile">Profile</a></li>
            ) : (
              <li class="account-link"><a href="/account/login">Log in</a></li>
            )
          }
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="social-links">
        <a href="https://instagram.com/avlfilm" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        <a href="https://join.slack.com/t/avlfilm/shared_invite/zt-318cqm6e9-45oJ41NbnqzThOfEIX2CPQ" target="_blank" rel="noopener noreferrer" aria-label="Slack">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/>
          </svg>
        </a>
      </div>
    </footer>

    <Analytics />
    <SpeedInsights />

    <style>
      .admin-menu {
        position: relative;
      }

      .admin-menu-toggle {
        background: none;
        border: none;
        padding: 0;
        font-size: 1.1rem;
        line-height: 1;
        cursor: pointer;
      }

      .admin-menu-dropdown {
        position: absolute;
        right: 0;
        top: calc(100% + 0.6rem);
        z-index: 100;
        display: none;
        flex-direction: column;
        padding: 0.4rem;
        background: #fff;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-card);
      }

      .admin-menu-dropdown.open {
        display: flex;
      }

      .admin-menu-dropdown a {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        white-space: nowrap;
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
        color: var(--color-text-secondary);
        border-radius: var(--radius-sm);
        text-decoration: none;
      }

      .admin-menu-dropdown a:hover {
        background: var(--color-bg-subtle);
      }

      .mi-icon {
        display: inline-flex;
        flex-shrink: 0;
        color: var(--color-text-muted);
      }

      .admin-menu-dropdown hr {
        margin: 0.4rem 0;
        border: none;
        border-top: 1px solid var(--color-border);
      }
    </style>

    <script>
      const toggle = document.getElementById('admin-menu-toggle');
      const dropdown = document.getElementById('admin-menu-dropdown');

      if (toggle && dropdown) {
        const close = () => {
          dropdown.classList.remove('open');
          toggle.setAttribute('aria-expanded', 'false');
        };

        toggle.addEventListener('click', (e) => {
          e.stopPropagation();
          const open = dropdown.classList.toggle('open');
          toggle.setAttribute('aria-expanded', String(open));
        });

        // Close on outside click or Escape
        document.addEventListener('click', (e) => {
          if (!dropdown.contains(e.target as Node)) close();
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') close();
        });
      }
    </script>
  </body>
</html>
